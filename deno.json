{
  "tasks": {
    "dev": "deno run -A scripts/build.ts && deno run -A npm:wrangler dev",
    "build": "deno run -A scripts/build.ts",
    "build:extension": "deno run -A scripts/build.ts --extension-only",
    "zip:extension": "deno run -A scripts/zip-extension.ts",
    "setup": "deno run -A scripts/setup.ts",
    "telegram:setup": "deno run -A scripts/telegram-setup.ts",
    "deploy": "deno task build && deno run -A npm:wrangler deploy",
    "test": "deno test -A",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "hono": "npm:hono@^4.6.0",
    "esbuild": "npm:esbuild@^0.24.0",
    "linkedom": "npm:linkedom@^0.18.13",
    "@mozilla/readability": "npm:@mozilla/readability@^0.6.0",
    "preact": "npm:preact@^10.29.7",
    "preact/hooks": "npm:preact@^10.29.7/hooks",
    "preact/jsx-runtime": "npm:preact@^10.29.7/jsx-runtime",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@clipfeed/shared/types": "./packages/shared/src/types.ts"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "fmt": {
    "lineWidth": 100
  },
  "allowScripts": ["npm:sharp", "npm:workerd"]
}
